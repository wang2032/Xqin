# 镜像地址（小写，改成你的 GitHub 用户名/组织）
APP_IMAGE=ghcr.io/your-name/i_love_day:latest

# 对外暴露的宿主机端口（非常用端口，后续由你的 Nginx 反代指向这个端口）
APP_PORT=18923

# 外部 MySQL 连接信息
# 若 MySQL 跑在宿主机上，DB_HOST 填 host.docker.internal
DB_HOST=
DB_PORT=3306
DB_NAME=i_love_day
DB_USER=
DB_PASSWORD=
DB_CHARSET=utf8mb4

# 安全密钥，生成命令： php -r "echo bin2hex(random_bytes(16));"
APP_SECRET_KEY=

# 调试模式：留空=关闭；排查首次部署问题时可临时设为 1
APP_DEBUG=
