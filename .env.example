# 镜像地址（小写，改成你的 GitHub 用户名/组织）
APP_IMAGE=ghcr.io/wang2032/xqin:latest

# 对外暴露的宿主机端口（非常用端口，后续由你的 Nginx 反代指向这个端口）
APP_PORT=18923

# 数据库（MySQL 随这套 compose 一起启动，无需外部数据库）
# 库名
DB_NAME=i_love_day
# 数据库密码：同时作为 MySQL root 密码与应用连接密码，请改成强随机串
DB_PASSWORD=change_me_to_a_strong_password

# 安全密钥，生成命令： php -r "echo bin2hex(random_bytes(16));"
# 没有 php 也可用： openssl rand -hex 16
APP_SECRET_KEY=

# 调试模式：留空=关闭；排查首次部署问题时可临时设为 1
APP_DEBUG=
